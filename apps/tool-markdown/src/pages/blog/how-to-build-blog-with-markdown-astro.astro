import BlogLayout from '../../layouts/BlogLayout.astro';

const yamlFront = "---\ntitle: 'My First Post'\ndate: 2026-04-29\ntags: [markdown, astro, blog]\n---\n\nWelcome to my blog!";
const configCode = "import { defineConfig } from 'astro/config';\nimport mdx from '@astrojs/mdx';\nimport sitemap from '@astrojs/sitemap';\n\nexport default defineConfig({\n  site: 'https://myblog.com',\n  integrations: [mdx(), sitemap()],\n  markdown: {\n    shikiConfig: {\n      theme: 'github-dark',\n      wrap: true,\n    },\n  },\n});";
const layoutCode = "---\n// src/layouts/BlogLayout.astro\nexport interface Props {\n  title: string;\n  description: string;\n  publishedDate: string;\n  tags?: string[];\n}\n\nconst { title, description, publishedDate, tags } = Astro.props;\n---\n\n<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <title>{title}</title>\n    <meta name=\"description\" content={description} />\n  </head>\n  <body>\n    <nav><a href=\"/\">Home</a> › <a href=\"/blog\">Blog</a></nav>\n    <article>\n      <h1>{title}</h1>\n      <p class=\"meta\">Published {publishedDate}</p>\n      <slot />\n    </article>\n  </body>\n</html>";
const listPageCode = "---\nimport { getCollection } from 'astro:content';\n\nconst posts = await getCollection('blog');\nconst sortedPosts = posts\n  .filter(post => !post.data.draft)\n  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());\n---\n\n<h1>Blog</h1>\n{posts.map(post => (\n  <article>\n    <h2><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>\n    <p>{post.data.description}</p>\n    <small>{post.data.date.toLocaleDateString()}</small>\n  </article>\n))}";
const schemaCode = "<pre><code>import { defineCollection, z } from 'astro:content';\n\nexport const collections &plus; {\n  blog: defineCollection({\n    type: 'content',\n    schema: z.object({\n      title: z.string(),\n      date: z.date(),\n      tags: z.array(z.string()).optional(),\n      draft: z.boolean().optional(),\n    }),\n  }),\n};\n</code></pre>";
const slugRouteCode = "<pre><code>---\nimport type { GetStaticPaths } from 'astro';\nimport { getCollection } from 'astro:content';\n\nexport const getStaticPaths &plus; (async () => {\n  const blogPosts &plus; await getCollection('blog');\n  return blogPosts.map((post) => ({\n    params: { slug: post.slug },\n    props: { post },\n  }));\n}) satisfies GetStaticPaths;\n---\n\n&lt;!-- Astro renders the Markdown content inline here. --&gt;\n&lt;!-- The page template wraps your content with layout and styles. --&gt;\n</code></pre>";

const jsonld = {
  "@context": "https://schema.org",
