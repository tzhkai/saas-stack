---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pricing - MarkdownMaster (Free)"
  description="MarkdownMaster is completely free. No signup, no credit card, no limits. Open source Markdown editor."
  canonical="https://markdownmaster.site/pricing/"
>
  <style>
    .hero { text-align:center; padding:3rem 1.5rem; }
    .hero h1 { font-size:2rem; margin-bottom:0.5rem; }
    .hero p { color:var(--text-dim); }
    .pricing-grid { display:grid; grid-template-columns:minmax(300px,400px); justify-content:center; gap:1.5rem; padding:2rem 1.5rem 4rem; }
    .card { background:var(--bg-card); border:2px solid var(--accent); border-radius:16px; padding:2rem; text-align:center; }
    .card h2 { font-size:1.3rem; margin-bottom:0.5rem; }
    .price { font-size:3rem; font-weight:700; margin:0.5rem 0; }
    .price span { font-size:1rem; color:var(--text-dim); font-weight:400; }
    .card ul { list-style:none; padding:0; margin:1.5rem 0; text-align:left; }
    .card li { padding:0.5rem 0; color:#cbd5e1; display:flex; align-items:center; gap:0.5rem; }
    .card li::before { content:'\2713'; color:#22c55e; font-weight:700; }
    .card .btn { display:inline-block; padding:0.75rem 2.5rem; background:var(--accent); color:#fff; text-decoration:none; border-radius:8px; font-weight:600; transition:background 0.15s; }
    .card .btn:hover { background:var(--accent-hover); }
  </style>

  <section class="hero">
    <h1>Simple, Free Pricing</h1>
    <p>MarkdownMaster is completely free. No credit card required.</p>
  </section>

  <div class="pricing-grid">
    <div class="card">
      <h2>Free</h2>
      <div class="price">$0<span>/month</span></div>
      <ul>
        <li>Unlimited documents</li>
        <li>Real-time preview</li>
        <li>All export formats</li>
        <li>No signup required</li>
        <li>Syntax highlighting</li>
      </ul>
      <a href="/editor/" class="btn">Get Started</a>
    </div>
  </div>
</BaseLayout>
